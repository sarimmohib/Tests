// GENERAL KNOWLEDGE (Qs 191–200)
// =====================================================
Subj1:"General Knowledge"/Chap1:"Pakistan"/Topi1:"Dams"/Type1:"K"/Diff1:"E"/Stem1:"" { q{ Q:"The Dasu hydro power project is to be built on river" A:"d" O:a)"Jhelum",b)"Chenab",c)"Ravi",d)"Indus" R:"Dasu is on Indus." } }
Subj1:"General Knowledge"/Chap1:"Pakistan"/Topi1:"Literary Organizations"/Type1:"K"/Diff1:"M"/Stem1:"" { q{ Q:"The headquarters of Anjuman Taraqqi-i-Urdu is located in" A:"b" O:a)"Lahore",b)"Karachi",c)"Rawalpindi",d)"Multan" R:"Anjuman Taraqqi-i-Urdu is based in Karachi." } }
Subj1:"General Knowledge"/Chap1:"Pakistan"/Topi1:"APNS"/Type1:"K"/Diff1:"M"/Stem1:"" { q{ Q:"The incumbent president of All Pakistan Newspaper Society (APNS) is" A:"d" O:a)"Aslam Chelas",b)"Burhan ud Din",c)"Furrukh Niazi",d)"Hameed Haroon" R:"Hameed Haroon was president as of 2014." } }
Subj1:"General Knowledge"/Chap1:"Environment"/Topi1:"Earth Hour"/Type1:"K"/Diff1:"E"/Stem1:"" { q{ Q:"When was Earth Hour observed?" A:"c" O:a)"1 April 2014",b)"22 March 2014",c)"29 March 2014",d)"31 March 2014" R:"Earth Hour 2014 was March 29." } }
Subj1:"General Knowledge"/Chap1:"Books"/Topi1:"Authors"/Type1:"K"/Diff1:"M"/Stem1:"" { q{ Q:"Book titled 'The Wrong Enemy: America in Afghanistan 2001-2014' has been written by" A:"a" O:a)"Carlotta Gall",b)"Henderson Brooks",c)"Neville Maxwell",d)"None" R:"Carlotta Gall is the author." } }
Subj1:"General Knowledge"/Chap1:"Environment"/Topi1:"World Water Day"/Type1:"K"/Diff1:"E"/Stem1:"" { q{ Q:"When is World Water Day celebrated annually?" A:"a" O:a)"22 March",b)"5 March",c)"13 March",d)"20 March" R:"22 March." } }
Subj1:"General Knowledge"/Chap1:"Books"/Topi1:"Authors"/Type1:"K"/Diff1:"M"/Stem1:"" { q{ Q:"Who is the author of the book 'The Sahara Testaments'?" A:"a" O:a)"Tade Ipadeola",b)"Rebecca Hunt",c)"Abdul Kalam",d)"Victoria Grassack" R:"Tade Ipadeola wrote 'The Sahara Testaments'." } }
Subj1:"General Knowledge"/Chap1:"Pakistan"/Topi1:"Competition Commission"/Type1:"K"/Diff1:"M"/Stem1:"" { q{ Q:"Who is currently acting chairman of the Competition Commission of Pakistan?" A:"c" O:a)"Rahat Kaunain",b)"Muhammad Zubair",c)"Nadeem ul Haq",d)"Dr. Joseph Wilion" R:"Nadeem ul Haq was acting chairman circa 2014." } }
Subj1:"General Knowledge"/Chap1:"World Leaders"/Topi1:"Italy PM"/Type1:"K"/Diff1:"M"/Stem1:"" { q{ Q:"The incumbent P.M. of Italy is" A:"d" O:a)"Mario Monti",b)"Lamberto Dini",c)"Enrico Letta",d)"Matteo Renzi" R:"Matteo Renzi was PM in 2014." } }
Subj1:"General Knowledge"/Chap1:"Pakistan"/Topi1:"Sports"/Type1:"K"/Diff1:"M"/Stem1:"" { q{ Q:"Who won the Cholistan Jeep Rally 2014?" A:"a" O:a)"Ali Hassan Baloch",b)"Qasiar Khan Rind",c)"Nadir Ali Magsi",d)"Ayaz Latif Chandio" R:"Ali Hassan Baloch won in 2014." } }