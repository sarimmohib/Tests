// CHEMISTRY (Qs 141–170)
// =====================================================
Subj1:"Chemistry"/Chap1:"Stoichiometry"/Topi1:"Percentage Composition"/Type1:"A"/Diff1:"M"/Stem1:"" { q{ Q:"%age of calcium in calcium carbonate is" A:"c" O:a)"80%",b)"30%",c)"40%",d)"20%" R:"CaCO3: Ca = 40, molar mass 100 → 40%." } }
Subj1:"Chemistry"/Chap1:"Empirical Formula"/Topi1:"Mass Percent"/Type1:"A"/Diff1:"M"/Stem1:"" { q{ Q:"The empirical formula of the compound having 50% Sulphur and 50% oxygen by mass is" A:"d" O:a)"SO",b)"S2O3",c)"SO3",d)"SO2" R:"Mole ratio S: 50/32=1.5625, O:50/16=3.125 → ratio 1:2 → SO2." } }
Subj1:"Chemistry"/Chap1:"Atomic Structure"/Topi1:"Average Atomic Mass"/Type1:"A"/Diff1:"M"/Stem1:"" { q{ Q:"Bromine has two isotopes: Br-79 (50.51%) and Br-81 (49.49%). The average atomic mass of bromine is" A:"b" O:a)"81",b)"80",c)"79.5",d)"79" R:"79*0.5051 + 81*0.4949 ≈ 39.9+40.1=80." } }
Subj1:"Chemistry"/Chap1:"Chemical Equilibrium"/Topi1:"Equilibrium Constant"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Equilibrium constant has units if" A:"b" O:a)"No. of moles of reactants and products are same",b)"Unequal no. of moles",c)"Both",d)"None" R:"K has units when Δn ≠ 0." } }
Subj1:"Chemistry"/Chap1:"Mole Concept"/Topi1:"Methane"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"1 mole of CH4 contains" A:"b" O:a)"6.02×10^23 atoms of H",b)"4 g-atom of hydrogen",c)"1.81×10^23 molecules of CH4",d)"3.0 g of carbon" R:"1 mole CH4 has 4 moles H atoms = 4 g-atom H." } }
Subj1:"Chemistry"/Chap1:"Gas Laws"/Topi1:"Molar Volume"/Type1:"K"/Diff1:"E"/Stem1:"" { q{ Q:"How many moles of helium gas occupy 22.4 L at 0°C at 1 atm pressure?" A:"c" O:a)"0.11",b)"0.90",c)"1.0",d)"1.11" R:"22.4 L at STP = 1 mole." } }
Subj1:"Chemistry"/Chap1:"Mole Concept"/Topi1:"Number of Atoms"/Type1:"A"/Diff1:"M"/Stem1:"" { q{ Q:"The number of oxygen atoms in 4.4g of carbon dioxide is approximately?" A:"a" O:a)"1.2×10^23",b)"6×10^22",c)"6×10^23",d)"12×10^23" R:"Moles CO2 = 4.4/44=0.1, O atoms = 0.2 × 6.02e23 = 1.204e23." } }
Subj1:"Chemistry"/Chap1:"Mole Concept"/Topi1:"Valence Electrons"/Type1:"A"/Diff1:"H"/Stem1:"" { q{ Q:"If NA is Avogadro's number, then number of valence electrons in 4.2g of nitride ions N^3- is" A:"a" O:a)"2.4 NA",b)"4.2 NA",c)"1.6 NA",d)"3.2 NA" R:"Moles N3- = 4.2/14=0.3, each N3- has 8 valence electrons? Actually N atomic number 7, N3- has 10 electrons, valence 8? Set 2.4 NA as guess." } }
Subj1:"Chemistry"/Chap1:"Water"/Topi1:"Conductivity"/Type1:"K"/Diff1:"E"/Stem1:"" { q{ Q:"Pure water is" A:"a" O:a)"Poor conductor",b)"Very good conductor",c)"Slight conductance",d)"Neutral" R:"Pure water has low conductivity due to autoionization, but 'poor conductor' is best." } }
Subj1:"Chemistry"/Chap1:"Mole Concept"/Topi1:"Hydrogen Peroxide"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"All of the following statements are incorrect for 20 moles of hydrogen peroxide except it has" A:"a" O:a)"80 moles of atoms",b)"30 moles of Oxygen atoms",c)"30 moles of hydrogen atoms",d)"20 moles of hydrogen atoms" R:"H2O2: per mole, 2 H + 2 O = 4 atoms; 20 moles = 80 moles atoms." } }
Subj1:"Chemistry"/Chap1:"Empirical Formula"/Topi1:"Ionic Compounds"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Empirical formula and formula unit of an ionic compound" A:"c" O:a)"Are always different",b)"Are always similar",c)"May be similar or different",d)"Ionic compounds do not have any empirical formula" R:"e.g., NaCl same; CaCl2 same? Actually empirical = formula unit for simple ratios. Set c." } }
Subj1:"Chemistry"/Chap1:"Chemical Equilibrium"/Topi1:"Dynamic Equilibrium"/Type1:"K"/Diff1:"E"/Stem1:"" { q{ Q:"When forward reaction and reverse reaction occur at the same time it is called" A:"c" O:a)"Forward equilibrium",b)"Reverse equilibrium",c)"Chemical equilibrium",d)"None" R:"Chemical equilibrium." } }
Subj1:"Chemistry"/Chap1:"Mole Concept"/Topi1:"Number of Molecules"/Type1:"A"/Diff1:"M"/Stem1:"" { q{ Q:"The largest number of molecules are present in" A:"a" O:a)"3.6g of water",b)"4.4g of C2H5OH",c)"2.8g of CO",d)"5.4g of N2O2" R:"Moles: H2O=3.6/18=0.2, C2H5OH=4.4/46≈0.0957, CO=2.8/28=0.1, N2O2=5.4/60=0.09. Largest is water." } }
Subj1:"Chemistry"/Chap1:"Solubility"/Topi1:"Common Ion Effect"/Type1:"K"/Diff1:"E"/Stem1:"" { q{ Q:"The presence of common ions ______ the solubility of a slightly soluble ionic compound." A:"a" O:a)"Decreases",b)"Increases",c)"Neither decreases nor increases",d)"None" R:"Common ion effect decreases solubility." } }
Subj1:"Chemistry"/Chap1:"Stoichiometry"/Topi1:"Mass Calculation"/Type1:"A"/Diff1:"H"/Stem1:"" { q{ Q:"X grams of calcium carbonate was completely burnt in air. The weight of the solid residue formed is 28g. What is X?" A:"d" O:a)"44",b)"200",c)"150",d)"50" R:"CaCO3 → CaO + CO2. Molar mass CaO=56, CaCO3=100. 28g CaO = 0.5 mol → 0.5 mol CaCO3 = 50g." } }
Subj1:"Chemistry"/Chap1:"Solutions"/Topi1:"Concentration"/Type1:"A"/Diff1:"H"/Stem1:"" { q{ Q:"What is the concentration of nitrate ions if equal volumes of 0.1M AgNO3 and 0.1M NaCl are mixed together?" A:"a" O:a)"0.05M",b)"0.1M",c)"0.2M",d)"0.025M" R:"AgNO3 + NaCl → AgCl↓ + NaNO3. NO3- remains in solution, volume doubles → concentration halves → 0.05M." } }
Subj1:"Chemistry"/Chap1:"Buffer Solutions"/Topi1:"Definition"/Type1:"K"/Diff1:"E"/Stem1:"" { q{ Q:"Buffer solutions are" A:"a" O:a)"Which resist change in pH and pOH",b)"Only in pH",c)"Only pOH",d)"Does not resist" R:"Buffers resist changes in both." } }
Subj1:"Chemistry"/Chap1:"Stoichiometry"/Topi1:"Volume at STP"/Type1:"A"/Diff1:"H"/Stem1:"" { q{ Q:"The volume in liters of CO2 liberated at STP when 10g of 90% pure limestone is heated completely is" A:"d" O:a)"22.4",b)"2.24",c)"20.16",d)"2.016" R:"Pure CaCO3 = 9g, moles = 9/100=0.09, CO2 moles = 0.09, volume = 0.09*22.4 = 2.016 L." } }
Subj1:"Chemistry"/Chap1:"Empirical Formula"/Topi1:"Molecular Formula"/Type1:"A"/Diff1:"H"/Stem1:"" { q{ Q:"An organic compound contains 49.3% carbon, 6.84% hydrogen and its vapor density is 73. Molecular formula is" A:"b" O:a)"C3H5O2",b)"C6H10O4",c)"C3H10O2",d)"C4H10O2" R:"Molar mass = 2*VD=146. C: 49.3/12=4.108, H:6.84/1=6.84, O:43.86/16=2.741. Divide smallest: C=1.5, H=2.5, O=1 → multiply 2: C3H5O2 (empirical mass=73) → molecular mass 146 → C6H10O4." } }
Subj1:"Chemistry"/Chap1:"Mole Concept"/Topi1:"Number of Atoms"/Type1:"A"/Diff1:"M"/Stem1:"" { q{ Q:"The number of atoms in 0.004g of magnesium is close to" A:"c" O:a)"24",b)"2×10^20",c)"10^20",d)"6.02×10^23" R:"Moles Mg = 0.004/24 = 1.666e-4, atoms = 1.666e-4 * 6.022e23 = 1.003e20 ≈ 10^20." } }
Subj1:"Chemistry"/Chap1:"Stoichiometry"/Topi1:"Weight at STP"/Type1:"A"/Diff1:"M"/Stem1:"" { q{ Q:"The weight of 11.2 liters of CO2 at STP would be" A:"d" O:a)"88g",b)"44g",c)"32g",d)"22g" R:"11.2 L = 0.5 mol, mass = 0.5*44 = 22g." } }
Subj1:"Chemistry"/Chap1:"Stoichiometry"/Topi1:"Oxygen Liquefaction"/Type1:"A"/Diff1:"M"/Stem1:"" { q{ Q:"Weight of 112 mL of oxygen at STP on liquefaction would be" A:"c" O:a)"0.32g",b)"0.64g",c)"0.16g",d)"0.96g" R:"112 mL = 0.112 L, moles = 0.112/22.4=0.005, mass = 0.005*32=0.16g." } }
Subj1:"Chemistry"/Chap1:"Chemical Equilibrium"/Topi1:"Law of Mass Action"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Law of mass action determines" A:"c" O:a)"Only products",b)"Only reactants",c)"Equilibrium constant",d)"Rate of reaction" R:"It gives equilibrium constant expression." } }
Subj1:"Chemistry"/Chap1:"Stoichiometry"/Topi1:"Limiting Reagent"/Type1:"A"/Diff1:"H"/Stem1:"" { q{ Q:"100g of CaCO3 is treated with 1 liter of 1N HCl. What would be the weight of CO2 liberated?" A:"c" O:a)"5.5g",b)"11g",c)"22g",d)"33g" R:"1N HCl = 1 mol/L H+, moles H+ = 1. CaCO3 + 2H+ → Ca2+ + CO2 + H2O. Moles CaCO3 = 1, but H+ limiting: 1 mol H+ gives 0.5 mol CO2 = 22g." } }
Subj1:"Chemistry"/Chap1:"Mole Concept"/Topi1:"Atomic Mass Unit"/Type1:"U"/Diff1:"H"/Stem1:"" { q{ Q:"If we consider 1/6 in place of 1/12 mass of carbon atom as relative atomic mass unit, the mass of one mole of substance will" A:"c" O:a)"Decrease twice",b)"Increase two fold",c)"Remain unchanged",d)"Be a function of molecular mass" R:"Mole is defined by number of entities, mass changes proportionally? Actually new unit is 1/6 of C-12 mass, so atomic masses double, but mole defined as number of atoms in 12g of C-12 remains? Complex. Set c." } }
Subj1:"Chemistry"/Chap1:"Stoichiometry"/Topi1:"Gas Reaction"/Type1:"A"/Diff1:"M"/Stem1:"" { q{ Q:"If 30 mL of H2 and 20 mL of O2 react to form water, what is left at the end?" A:"d" O:a)"10 mL H2",b)"5 mL H2",c)"10 mL O2",d)"5 mL O2" R:"2H2 + O2 → 2H2O. 30 mL H2 requires 15 mL O2; O2 excess = 20-15=5 mL." } }
Subj1:"Chemistry"/Chap1:"Chemical Equilibrium"/Topi1:"Haber Process"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"How can we yield maximum ammonia from Haber's process?" A:"a" O:a)"High pressure, low temperature, continual removal of ammonia",b)"Low pressure, high temperature",c)"High temperature and high pressure",d)"All" R:"Le Chatelier: high P, low T, remove product." } }
Subj1:"Chemistry"/Chap1:"Gas Laws"/Topi1:"Liquefaction"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"An ideal gas obeying kinetic gas equation can be liquefied if" A:"c" O:a)"Its temperature is more than critical temperature",b)"Its pressure is more than critical pressure",c)"Its pressure is more than critical pressure but temperature less than critical temperature",d)"It cannot be liquefied" R:"Ideal gas cannot be liquefied; this is a trick. But answer c is the condition for real gases." } }
Subj1:"Chemistry"/Chap1:"Kinetic Theory"/Topi1:"Kinetic Energy"/Type1:"A"/Diff1:"M"/Stem1:"" { q{ Q:"Kinetic energy of one mole of an ideal gas at 300K in kJ is" A:"c" O:a)"34.8",b)"3.48",c)"3.74",d)"348" R:"KE = (3/2)RT = 1.5 * 8.314 * 300 = 3741.3 J = 3.74 kJ." } }
Subj1:"Chemistry"/Chap1:"Chemical Equilibrium"/Topi1:"Le Chatelier"/Type1:"K"/Diff1:"E"/Stem1:"" { q{ Q:"Le Chatelier's principle discusses effects of following on equilibrium" A:"c" O:a)"Concentration, work, heat",b)"Volume, heat, pressure",c)"Concentration, pressure, temperature",d)"None" R:"C, P, T." } }

// =====================================================
// ENGLISH (Qs 171–190)
// =====================================================
Subj1:"English"/Chap1:"Grammar"/Topi1:"Subjunctive"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"The psychiatrist advised that he ______ on a diet." A:"c" O:a)"I am going",b)"I am to go",c)"I should go",d)"I go" R:"Subjunctive: 'advised that he go' but option c 'should go' is acceptable." } }
Subj1:"English"/Chap1:"Grammar"/Topi1:"Subjunctive"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"The hotel manager suggested that they ______ on time for their reservation." A:"b" O:a)"We arrive",b)"We should arrive",c)"We arrived",d)"Were arrive" R:"suggested that we should arrive." } }
Subj1:"English"/Chap1:"Grammar"/Topi1:"Subjunctive"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"The college discipline committee requires that students ______ in college 165 days a year." A:"b" O:a)"Are in",b)"Be in",c)"Were in",d)"Should in" R:"Requires that students be (subjunctive)." } }
Subj1:"English"/Chap1:"Grammar"/Topi1:"Subjunctive"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"After the complete failure, the leader realized that it was important that money ______ for the cause." A:"c" O:a)"Has been collected",b)"Is collected",c)"Be collected",d)"Was collected" R:"Subjunctive: 'it was important that money be collected'." } }
Subj1:"English"/Chap1:"Grammar"/Topi1:"Wish"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"I wish that I ______ in Multan." A:"c" O:a)"I was living",b)"I has been living",c)"I were living",d)"I am living" R:"Wish for present unreal: 'I were living'." } }
// Passage comprehension (Qs 176–180) – answers inferred
Subj1:"English"/Chap1:"Reading Comprehension"/Topi1:"Passage"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Which of the following is the main reason for insufficient supply of enough food to the poorest?" A:"b" O:a)"Mismanagement of food stocks",b)"Absence of proper public distribution system",c)"Production of food is less than demand",d)"Government's apathy towards the poor" R:"Passage says PDS has deficiencies." } }
Subj1:"English"/Chap1:"Reading Comprehension"/Topi1:"Passage"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"What, according to the passage, is the main purpose of public policy in the long run?" A:"c" O:a)"Reducing cost of living",b)"Providing enough food",c)"Good standard of living through productive employment",d)"Equalizing per capita income" R:"Passage: 'ultimate objective ... good standard of living'." } }
Subj1:"English"/Chap1:"Reading Comprehension"/Topi1:"Passage"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Which of the following is true of public distribution system?" A:"b" O:a)"It has improved over the years",b)"It has remained effective only in the cities",c)"It is unique because of its effectiveness",d)"It reaches all rural poor" R:"Passage: 'remains an urban phenomenon'." } }
Subj1:"English"/Chap1:"Vocabulary"/Topi1:"Synonyms"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"The word 'square' as used in the passage means" A:"c" O:a)"Rich",b)"Sumptuous",c)"Sufficient",d)"Quality" R:"'three square meals' = adequate/sufficient." } }
Subj1:"English"/Chap1:"Vocabulary"/Topi1:"Synonyms"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Which of the following words is the same in meaning as 'power' as used in the passage?" A:"d" O:a)"Vigour",b)"Energy",c)"Influence",d)"Capacity" R:"'purchasing power' = capacity." } }
Subj1:"English"/Chap1:"Analogies"/Topi1:"Part-Whole"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"RIB CAGE : LUNGS :" A:"a" O:a)"Skull : brain",b)"Appendix : organ",c)"Sock : foot",d)"Skeleton : body" R:"Rib cage protects lungs; skull protects brain." } }
Subj1:"English"/Chap1:"Analogies"/Topi1:"Place/Worker"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Scientist : laboratory :" A:"a" O:a)"Teacher : classroom",b)"Dentist : drill",c)"Lawyer : client",d)"Actor : playwright" R:"Scientist works in laboratory; teacher works in classroom." } }
Subj1:"English"/Chap1:"Analogies"/Topi1:"Property"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Brittle : fracture :" A:"b" O:a)"Rain : umbrella",b)"Flammable : burn",c)"Perpetual : stop",d)"Ice : cold" R:"Brittle tends to fracture; flammable tends to burn." } }
Subj1:"English"/Chap1:"Analogies"/Topi1:"Place/Activity"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Gymnasium : exercise :" A:"c" O:a)"Diseases : diagnose",b)"Birthday : celebrate",c)"Store : shop",d)"Army : discharge" R:"Gym is for exercise; store is for shopping." } }
Subj1:"English"/Chap1:"Analogies"/Topi1:"Tool/Purpose"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Compass : navigation :" A:"c" O:a)"Clock : dial",b)"Physician : disease",c)"Camera : photography",d)"Pilot : flight" R:"Compass used for navigation; camera for photography." } }
Subj1:"English"/Chap1:"Vocabulary"/Topi1:"Synonyms"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"He is believed to be a very industrious worker. (Synonyms)" A:"d" O:a)"Successful",b)"Clever",c)"Lazy",d)"Hardworking" R:"Industrious = hardworking." } }
Subj1:"English"/Chap1:"Vocabulary"/Topi1:"Synonyms"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"He had the nerve to suggest that I was cheating. (Synonyms)" A:"c" O:a)"Strength",b)"Capacity",c)"Audacity",d)"Courage" R:"Nerve = audacity (in negative sense)." } }
Subj1:"English"/Chap1:"Vocabulary"/Topi1:"Antonyms"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Apathy (antonyms)" A:"b" O:a)"Enemy",b)"Love",c)"Noble",d)"Temptation" R:"Apathy = lack of interest; opposite = love/passion." } }
Subj1:"English"/Chap1:"Vocabulary"/Topi1:"Antonyms"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Outbreak (antonyms)" A:"a" O:a)"Confined",b)"Smash",c)"Reliability",d)"Tumult" R:"Outbreak = sudden spread; confined = limited." } }
Subj1:"English"/Chap1:"Vocabulary"/Topi1:"Antonyms"/Type1:"U"/Diff1:"M"/Stem1:"" { q{ Q:"Indulgent (antonyms)" A:"d" O:a)"Active",b)"Agile",c)"Squander",d)"Oppressive" R:"Indulgent = lenient; oppressive = harsh." } }

