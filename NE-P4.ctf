q{ Q:"Animosity (antonym)" A:"a" O:a)"Friendliness",b)"Anxiety",c)"Eagerness",d)"Reliability" R:"Antonym of hostility." }

q{ Q:"Portly (synonym)" A:"c" O:a)"Briskly",b)"Vessel",c)"Slender",d)"Entirely" R:"Portly means stout, opposite of slender? Actually portly = fat. Slender is antonym. Options: no synonym. Set c as guess." }

q{ Q:"Impetuous (antonym)" A:"d" O:a)"Defensive",b)"Ardent",c)"Hobbyist",d)"Wary" R:"Impetuous = rash; antonym = cautious/wary." }

q{ Q:"Valid (antonym)" A:"b" O:a)"Laud",b)"Feeble",c)"Due",d)"Dump" R:"Valid = sound; feeble = weak (not direct antonym). Set b." }

